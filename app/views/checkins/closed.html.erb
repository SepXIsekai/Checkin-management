<div class="flex justify-center pt-20 px-4 bg-[#f8fafc]" data-testid="closed-page">
  <div class="bg-white rounded-2xl shadow-lg w-full max-w-sm p-8 text-center" data-testid="closed-container">
    <div class="flex justify-center mb-5" data-testid="error-icon">
      <div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center">
        <span class="text-red-600 text-2xl">✕</span>
      </div>
    </div>
    <h1 class="text-xl font-semibold text-slate-900 mb-2" data-testid="closed-title">
      Check-in Closed
    </h1>
    <p class="text-slate-500 text-sm mb-5" data-testid="course-info">
      <span class="font-medium"><%= @course.code %></span><br>
      <%= @course.name %>
    </p>
    <p class="text-slate-600 text-sm mb-6" data-testid="closed-message">
      The instructor has closed the attendance form.
    </p>
    <%= link_to "Back to Home",
      root_path,
      data: { testid: "back-to-home-btn" },
      class: "w-full inline-flex items-center justify-center bg-[#261ce6] text-white py-2.5 rounded-lg text-sm font-medium hover:bg-[#1a14a3] transition active:scale-[0.98]" %>
  </div>
</div>
