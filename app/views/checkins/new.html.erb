<!-- app/views/checkins/new.html.erb -->
<div class="flex justify-center px-4 py-10 bg-[#f8fafc]" data-testid="checkin-page">
  <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8"
       data-controller="checkin-location"
       data-testid="checkin-container">
    <h1 class="text-xl font-semibold text-slate-900 text-center mb-2" data-testid="page-title">
      Check-in
    </h1>
    <p class="text-center text-sm text-slate-500" data-testid="course-info">
      <span class="font-medium"><%= @course.code %></span> - <%= @course.name %>
    </p>
    <p class="text-center text-sm text-slate-400 mb-4" data-testid="form-title">
      <%= @checkin_form.title %>
    </p>
    <% if @checkin_form.onsite? %>
      <div class="bg-orange-50 text-orange-600 text-sm rounded-xl px-4 py-3 mb-6 flex items-center justify-center gap-2" data-testid="location-requirement">
        <%= image_tag "backoffice/location-pin-icon.svg", class: "w-6 h-6" %>
        <span>
          You must be within
          <span class="font-medium" data-testid="radius-value"><%= @checkin_form.radius %> meters</span>
        </span>
      </div>
    <% end %>
    <%# Show server-side validation errors (e.g., not within radius) %>
    <% if defined?(@attendance) && @attendance&.errors&.any? %>
      <div class="mb-4" data-testid="error-messages">
        <div class="bg-red-50 text-red-700 rounded-xl px-4 py-3 text-sm">
          <ul class="list-disc pl-5 space-y-1">
            <% @attendance.errors.full_messages.each do |msg| %>
              <li data-testid="error-message"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>
    <div class="bg-slate-50 rounded-xl p-4 text-sm text-slate-700 mb-6 space-y-1" data-testid="student-info">
      <p data-testid="student-id"><span class="font-medium">Student ID:</span> <%= current_user.student_id %></p>
      <p data-testid="student-name"><span class="font-medium">Name:</span> <%= current_user.name %></p>
    </div>
    <%= form_with url: checkin_path(@checkin_form.qr_token),
                  method: :post,
                  multipart: true,
                  data: { checkin_location_target: "form", testid: "checkin-form" } do |f| %>
      <%# Top-level attendance error summary removed. Per-field errors are shown inline. %>
      <%= hidden_field_tag :checkin_form_id, @checkin_form.id %>
      <% if @checkin_form.onsite? %>
        <%= hidden_field_tag :latitude, nil,
              data: { checkin_location_target: "latitude" } %>
        <%= hidden_field_tag :longitude, nil,
              data: { checkin_location_target: "longitude" } %>
      <% end %>
      <div class="mb-6" data-testid="photo-field">
        <label class="block text-sm font-medium text-slate-800 mb-2">
          Take a Selfie
        </label>
        <%= file_field_tag :photo,
              accept: "image/*",
              capture: "user",
              required: true,
              data: { testid: "photo-input" },
              class: "w-full text-sm border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#261ce6]" %>
        <p class="text-xs text-slate-400 mt-2">
          Please take a clear photo of yourself.
        </p>
      </div>
      <% if @checkin_form.onsite? %>
        <%= button_tag type: "button",
              data: { action: "click->checkin-location#getLocationAndSubmit", testid: "submit-with-location-btn" },
              class: "w-full h-12 rounded-xl bg-[#261ce6] text-white font-medium transition hover:bg-[#1a14a3] active:scale-[0.98] cursor-pointer" do %>
          Confirm Check-in
        <% end %>
      <% else %>
        <%= submit_tag "Confirm Check-in",
              data: { testid: "submit-btn" },
              class: "w-full h-12 rounded-xl bg-[#261ce6] text-white font-medium transition hover:bg-[#1a14a3] active:scale-[0.98] cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
</div>
