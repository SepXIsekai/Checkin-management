<%- if controller_name != 'sessions' %>
  <p data-testid="login-link-container"><%= link_to "Log in", new_session_path(resource_name), data: { testid: "login-link" } %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p data-testid="signup-link-container"><%= link_to "Sign up", new_registration_path(resource_name), data: { testid: "signup-link" } %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p data-testid="forgot-password-link-container"><%= link_to "Forgot your password?", new_password_path(resource_name), data: { testid: "forgot-password-link" } %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p data-testid="confirmation-link-container"><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), data: { testid: "confirmation-link" } %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p data-testid="unlock-link-container"><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), data: { testid: "unlock-link" } %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p data-testid="omniauth-<%= provider %>-container"><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false, testid: "omniauth-#{provider}-btn" } %></p>
  <% end %>
<% end %>
