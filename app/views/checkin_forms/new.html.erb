<div class="flex items-center border-b border-slate-200 bg-white/80 px-8 py-4 backdrop-blur-md" data-testid="checkin-form-header">
  <div class="flex flex-col items-start">
    <h1 class="text-xl font-bold" data-testid="page-title">Check-in Session</h1>
    <p class="text-sm text-gray-400 font-medium" data-testid="course-info"><%= @course.name %> • <%= @course.code %> • Year <%= @course.year %> • Semester <%= @course.semester %></p>
  </div>
</div>
<div class="m-10">
  <div class="flex justify-between items-baseline mb-8">
    <div>
      <div class="font-bold text-2xl text-black mb-1" data-testid="form-heading">
        Create New Session
      </div>
      <div class="text-sm text-slate-500" data-testid="form-description">
        Set up a new session for the current class.
      </div>
    </div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-6" data-testid="checkin-form-container">
    <%= form_with model: [@course, @checkin_form],
      data: { controller: "checkin-form", testid: "checkin-form" } do |f| %>
      <%# Top-level checkin form error summary removed. Per-field errors are shown inline. %>
      <div class="mb-4" data-testid="title-field-wrapper">
        <%= form_input(f, :title,
        label: "Form Title",
        type: :text,
        placeholder: "e.g. check in 21-02-2026",
        data_testid: "form-title-input") %>
      </div>
      <div class="mb-4" data-testid="mode-field-wrapper">
        <%= form_radio_group(
        f,
        :mode,
        label: "Mode",
        options: [
          ["Online", "online"],
          ["Onsite (Location Required)", "onsite"]
        ],
        checked: "online",
        data_action: "change->checkin-form#toggleMode",
        data_testid: "form-mode-radio"
      ) %>
      </div>
      <div class="mb-4 hidden" data-checkin-form-target="locationFields" data-testid="location-fields">
        <div class="bg-[#f8f8ff] p-5 rounded-xl border border-[#ececff] shadow-sm">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col">
              <%= f.label :latitude,
              "Latitude",
              class: "pb-2 text-sm font-medium text-[#111118]" %>
              <%= f.text_field :latitude,
              readonly: false,
              placeholder: "13.7563",
              data: { checkin_form_target: "latitude", testid: "latitude-input" },
              class: "h-12 px-4 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-[#261ce6]" %>
            </div>
            <div class="flex flex-col">
              <%= f.label :longitude,
              "Longitude",
              class: "pb-2 text-sm font-medium text-[#111118]" %>
              <%= f.text_field :longitude,
              readonly: false,
              placeholder: "100.5018",
              data: { checkin_form_target: "longitude", testid: "longitude-input" },
              class: "h-12 px-4 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-[#261ce6]" %>
            </div>
          </div>
          <div class="mt-4">
            <%= form_input(f, :radius,
            label: "Radius (meters)",
            type: :number,
            placeholder: "100",
            data_testid: "radius-input") %>
          </div>
          <button
          type="button"
          data-action="click->checkin-form#getCurrentLocation"
          data-testid="get-current-location-btn"
            class="mt-3 w-full h-12 rounded-xl
            bg-[#261ce6] text-white font-medium
            shadow-sm transition-all duration-200
            hover:bg-[#1f17c4] hover:shadow-md
            active:scale-[0.98] cursor-pointer">
            Use Current Location
          </button>
        </div>
      </div>
      <div class="flex gap-3 mt-6" data-testid="form-actions">
        <%= f.submit "Create",
        data: { testid: "submit-btn" },
        class: "h-12 px-6 rounded-xl
               bg-[#261ce6] text-white font-medium
               shadow-sm transition-all duration-200
               hover:bg-[#1f17c4] hover:shadow-md
               active:scale-[0.98]
               cursor-pointer" %>
        <%= link_to "Cancel",
        course_checkin_forms_path(@course),
        data: { testid: "cancel-btn" },
        class: "h-12 px-6 rounded-xl
               bg-white text-[#111118] font-medium
               border border-[#dcdce5]
               shadow-sm transition-all duration-200
               hover:bg-[#f5f5fa] hover:shadow-md
               active:scale-[0.98]
               flex items-center justify-center" %>
      </div>
    <% end %>
  </div>
</div>
