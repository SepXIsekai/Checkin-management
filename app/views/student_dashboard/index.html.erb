<div class="m-10">
  <h1 class="text-2xl font-bold mb-6" data-testid="page-title">My Attendance</h1>
  <% if @enrolled_courses.any? %>
    <div class="space-y-4" data-testid="courses-list">
      <% @enrolled_courses.each do |course| %>
        <% summary = @attendance_summary[course.id] %>
        <div class="bg-white border border-slate-200 rounded-2xl p-6" data-testid="course-card-<%= course.id %>">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="text-lg font-bold text-[#111827]" data-testid="course-code"><%= course.code %></h2>
              <p class="text-slate-500" data-testid="course-name"><%= course.name %></p>
              <p class="text-sm text-slate-400" data-testid="course-info">Year <%= course.year %> • Semester <%= course.semester %></p>
            </div>
            <div class="text-right">
              <p class="text-3xl font-bold text-[#261ce6]" data-testid="attended-count"><%= summary[:attended] %></p>
              <p class="text-sm text-slate-500" data-testid="total-sessions">of <%= summary[:total] %> sessions</p>
            </div>
          </div>
          <% if summary[:total] > 0 %>
            <div class="mt-4" data-testid="attendance-progress">
              <div class="w-full bg-slate-200 rounded-full h-2">
                <% percentage = (summary[:attended].to_f / summary[:total] * 100).round %>
                <div class="bg-[#261ce6] h-2 rounded-full" style="width: <%= percentage %>%" data-testid="progress-bar"></div>
              </div>
              <p class="text-sm text-slate-500 mt-1" data-testid="attendance-percentage"><%= percentage %>% attendance</p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white border border-slate-200 rounded-2xl p-12 text-center" data-testid="empty-courses">
      <p class="text-4xl mb-4">📚</p>
      <h2 class="text-lg font-bold text-[#111827] mb-2" data-testid="empty-title">No Courses Yet</h2>
      <p class="text-slate-500" data-testid="empty-message">You are not enrolled in any courses.</p>
    </div>
  <% end %>
</div>