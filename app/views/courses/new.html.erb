<% content_for :title, "New course" %>
<div class="flex items-center border-b border-slate-200 bg-white/80 px-8 py-6 backdrop-blur-md" data-testid="new-course-header">
  <h1 class="text-xl font-bold" data-testid="page-title">Course Management</h1>
</div>
<div class="m-12">
  <div class="flex justify-between items-baseline mb-8">
    <div>
      <div class="font-bold text-2xl text-black mb-1" data-testid="form-heading">
        Create New Course
      </div>
      <div class="text-sm text-slate-500" data-testid="form-description">
        Set up a new course for the current semester.
      </div>
    </div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-6" data-testid="course-form-container">
    <%= form_with model: @course,
      data: { controller: "nested-form", testid: "course-form" },
      class: "max-w-3xl" do |form| %>
      <%= render "form", form: form %>
      <div class="mt-12 flex justify-end gap-3" data-testid="form-actions">
        <%= link_to "Cancel", courses_path,
        data: { testid: "cancel-btn" },
        class: "px-6 py-2.5 text-sm font-semibold text-slate-500 hover:bg-slate-200 rounded-lg transition" %>
        <%= form.button type: "submit",
          data: { testid: "submit-btn" },
          class: "flex items-center gap-2 px-4 py-2.5 bg-[#261ce6] hover:bg-[#1a14a3] text-white text-sm font-semibold rounded-lg transition-all cursor-pointer" do %>
          <%= image_tag "backoffice/add-icon-white.svg", class: "w-5 h-5" %>
          Create Course
        <% end %>
      </div>
    <% end %>
  </div>
</div>
