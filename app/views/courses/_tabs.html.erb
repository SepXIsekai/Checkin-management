<!-- app/views/courses/_tabs.html.erb -->
<div class="mb-6 border-b" data-testid="course-tabs">
  <nav class="flex gap-4" data-testid="tabs-nav">
    <%= link_to "รายละเอียดวิชา", course_path(@course), 
        data: { testid: "tab-course-detail" },
        class: "py-2 px-1 border-b-2 #{current_page?(course_path(@course)) ? 'border-blue-600 text-blue-600' : 'border-transparent hover:border-slate-300'}" %>
    <%= link_to "นักศึกษา", "#", 
        data: { testid: "tab-students" },
        class: "py-2 px-1 border-b-2 border-transparent hover:border-slate-300" %>
    <%= link_to "เช็คชื่อ", "#", 
        data: { testid: "tab-checkin" },
        class: "py-2 px-1 border-b-2 border-transparent hover:border-slate-300" %>
  </nav>
</div>