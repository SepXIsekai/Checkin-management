<div id="<%= dom_id course %>" class="w-full sm:w-auto my-5 space-y-5" data-testid="course-detail">
  <div data-testid="course-code">
    <strong class="block font-medium mb-1">Code:</strong>
    <%= course.code %>
  </div>
  <div data-testid="course-name">
    <strong class="block font-medium mb-1">Name:</strong>
    <%= course.name %>
  </div>
  <div data-testid="course-year">
    <strong class="block font-medium mb-1">Year:</strong>
    <%= course.year %>
  </div>
  <div data-testid="course-semester">
    <strong class="block font-medium mb-1">Semester:</strong>
    <%= course.semester %>
  </div>
</div>
